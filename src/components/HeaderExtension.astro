---
import Logo from "../assets/svg/tagglo-logo.svg";
---

<div class="top-menu-holder text-sm w-full z-10 bg-desert">
  <div class="content-wrapper">
    <div class="content border-gray-200 border-b">
      <div class="flex justify-between items-center">
        <div class="flex items-center">
          <a href="/"><img src={Logo.src} width="110" height="48" alt="Tagglo logo" /></a>
        </div>

        <a
          href="https://chromewebstore.google.com/detail/tagglo-gtm-companion/agnanladhhogfjcldnhaiilamjabbjcc"
          target="_blank"
          rel="noopener noreferrer"
          class="install-extension-button rounded flex justify-center items-center text-white bg-black"
        >
          Install extension
        </a>
      </div>
    </div>
  </div>
</div>

<script is:inline>
  window.addEventListener("scroll", () => {
    const header = document.querySelector(".top-menu-holder");
    if (header) {
      if (window.scrollY >= 450) {
        header.classList.add("fixed", "animate__animated", "animate__slideInDown");
      }
      if (window.scrollY <= 450) {
        header.classList.remove("fixed", "animate__animated", "animate__slideInDown");
      }
    }
  });
</script>

<style lang="less">
  .install-extension-button {
    height: 36px;
    padding: 0 16px;
    font-size: 0.875rem;
    font-weight: 600;
    white-space: nowrap;
    transition: background-color 0.15s ease;
    &:hover {
      background-color: #1a1a1a;
    }
  }
</style>
